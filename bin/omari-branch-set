#!/bin/bash

# Set the branch for Omari's git repository.

if (($# == 0)); then
  echo "Usage: omari-branch-set [main|dev]"
  exit 1
else
  branch="$1"
fi

case "$branch" in
  "main") git -C $OMARI_PATH switch main ;;
  "dev") git -C $OMARI_PATH switch dev ;;
  *) echo "Unknown branch: $branch"; exit 1; ;;
esac
