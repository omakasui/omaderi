#!/bin/bash

# Creates a new Omari migration named after the unix timestamp of the last commit.
# Only intended for Omari developers.

cd ~/.local/share/omari
migration_file="$HOME/.local/share/omari/migrations/$(git log -1 --format=%cd --date=unix).sh"
touch $migration_file

if [[ "$1" != "--no-edit" ]]; then
  $EDITOR $migration_file
fi

echo $migration_file

