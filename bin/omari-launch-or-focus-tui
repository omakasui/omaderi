#!/bin/bash

# Launch or focus on a given TUI identified by the passed in as the command.
# Use by commands like omari-launch-wifi to ensure there is only one wifi configuration screen open.

APP_ID="org.omari.$(basename "$1")"
LAUNCH_COMMAND="omari-launch-tui $@"

exec omari-launch-or-focus "$APP_ID" "$LAUNCH_COMMAND"
