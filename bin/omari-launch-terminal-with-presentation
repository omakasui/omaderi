#!/bin/bash

# Launch a floating terminal with the Omari logo presentation, then execute the command passed in, and finally end with the omari-show-done presentation.
# Used by actions such as Update System.

cmd="$*"
xdg-terminal-exec bash -c "omari-show-logo; $cmd; if [ \$? -ne 130 ]; then omari-show-done; fi"
