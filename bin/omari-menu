show_remove_menu() {
  case $(menu "Remove" "Ό╜▓  Package\nΎΚρ  Web App\nΎΤΚ  TUI\n≤░Α╗  App\nΌψΠ  Style\n≤░╡χ  Development\n≤░ΠΥ  Preinstalls") in
  *Package*) terminal omari-pkg-remove ;;
  *Web*) present_terminal omari-webapp-remove ;;
  *TUI*) present_terminal omari-tui-remove ;;
  *App*) present_terminal omari-app-remove ;;
  *Style*) show_remove_style_menu ;;
  *Development*) show_remove_development_menu ;;
  *Preinstalls*) present_terminal omari-remove-preinstalls ;;
  *) show_main_menu ;;
  esac
}

show_remove_style_menu() {
  case $(menu "Remove" "≤░╕Ν  Theme\nΌββ  Font") in
  *Theme*) present_terminal omari-theme-remove ;;
  *Font*) show_remove_font_menu ;;
  *) show_remove_menu ;;
  esac
}

show_remove_font_menu() {
  case $(menu "Remove Font" "Όββ  Cascadia Mono\nΌββ  JetBrains Mono\nΌββ  iA Fonts\nΌββ  Microsoft Core Fonts" "--width 350") in
  *Cascadia*) remove_font "Cascadia Mono" "cascadia-mono" ;;
  *JetBrains*) remove_font "JetBrains Mono" "jetbrains-mono" ;;
  *iA*) remove_font "iA Fonts" "iafonts" ;;
  *Microsoft*) remove_font "Microsoft Core Fonts" "mscore" ;;
  *) show_remove_menu ;;
  esac
}

show_remove_development_menu() {
  case $(menu "Remove Development Environment" "≤░τΠ  Ruby on Rails\nΌηΒ  JavaScript\nΌαπ  Go\nΌε╜  PHP\nΌε╝  Python\nΌαφ  Elixir\nΌμψ  Zig\nΌηρ  Rust\nΌε╕  Java\nΌζ┐  .NET\nΌκΟ  OCaml\nΌζρ  Clojure\nΌε╖  Scala") in
  *Rails*) present_terminal "omari-remove-dev-env ruby" ;;
  *JavaScript*) show_remove_javascript_menu ;;
  *Go*) present_terminal "omari-remove-dev-env go" ;;
  *PHP*) present_terminal "omari-remove-dev-env php" ;;
  *Python*) present_terminal "omari-remove-dev-env python" ;;
  *Elixir*) show_remove_elixir_menu ;;
  *Zig*) present_terminal "omari-remove-dev-env zig" ;;
  *Rust*) present_terminal "omari-remove-dev-env rust" ;;
  *Java*) present_terminal "omari-remove-dev-env java" ;;
  *NET*) present_terminal "omari-remove-dev-env dotnet" ;;
  *OCaml*) present_terminal "omari-remove-dev-env ocaml" ;;
  *Clojure*) present_terminal "omari-remove-dev-env clojure" ;;
  *Scala*) present_terminal "omari-remove-dev-env scala" ;;
  *) show_remove_menu ;;
  esac
}

show_update_menu() {
  local brand_name=$(omari-brand)

  case $(menu "Update" "≤░θλ  $brand_name\n≤░Φτ  Channel\nΌαΧ  Config\n≤░╕Ν  Themes\nΌχλ  Process\n≤░ΘΖ  Hardware\nΌσ╕  Firmware\nΌυΣ  Password") in
  *$brand_name*) present_terminal omari-update ;;
  *Channel*) show_update_channel_menu ;;
  *Config*) show_update_config_menu ;;
  *Themes*) present_terminal omari-theme-update ;;
  *Process*) show_update_process_menu ;;
  *Hardware*) show_update_hardware_menu ;;
  *Firmware*) present_terminal omari-update-firmware ;;
  *Password*) show_update_password_menu ;;
  *) show_main_menu ;;
  esac
}

show_update_channel_menu() {
  case $(menu "Update channel" "Ώθθλ Stable\nΏθΦ┤ Dev") in
  *Stable*) present_terminal "omari-channel-set stable" ;;
  *Dev*) present_terminal "omari-channel-set dev" ;;
  *) show_update_menu ;;
  esac
}

show_update_config_menu() {
  case $(menu "Use default config" "ΎΞκ  Gnome\n≤░ΞΓ  GDM\nΎΕε  Keybindings\n≤▒μ┤  Plymouth\nΎΕ╡  Starship\nΌψΙ  Tmux\n≤░Νπ  Walker") in
  *Gnome*) present_terminal omari-refresh-gnome ;;
  *GDM*) present_terminal omari-refresh-gdm ;;
  *Keybindings*) present_terminal omari-refresh-keybindings ;;
  *Plymouth*) present_terminal omari-refresh-plymouth ;;
  *Starship*) present_terminal omari-refresh-config starship.toml ;;
  *Tmux*) present_terminal omari-refresh-tmux ;;
  *Walker*) present_terminal omari-refresh-walker ;;
  *) show_update_menu ;;
  esac
}

show_update_process_menu() {
  case $(menu "Restart" "≤░Νπ  Walker") in
  *Walker*) omari-restart-walker ;;
  *) show_update_menu ;;
  esac
}

show_update_hardware_menu() {
  case $(menu "Restart" "Όα╕  Audio") in
  *Audio*) present_terminal omari-restart-pipewire ;;
  *) show_update_menu ;;
  esac
}

show_update_password_menu() {
  case $(menu "Update Password" "ΌυΣ  User") in
  *User*) present_terminal passwd ;;
  *) show_update_menu ;;
  esac
}

show_about() {
  omari-launch-about
}

show_system_menu() {
  local options="≤░Ν╛  Lock"
  [[ ! -f ~/.local/state/omari/toggles/suspend-off ]] && options="$options\n≤░Τ▓  Suspend"
  options="$options\n≤░Ν╛  Logout\n≤░εΚ  Restart\n≤░Ρξ  Shutdown"

  case $(menu "System" "$options") in
  *Lock*) omari-system-lock-screen ;;
  *Suspend*) systemctl suspend ;;
  *Logout*) omari-system-logout ;;
  *Restart*) omari-system-reboot ;;
  *Shutdown*) omari-system-shutdown ;;
  *) back_to show_main_menu ;;
  esac
}

show_main_menu() {
  go_to_menu "$(menu "Go" "≤░Α╗  Apps\n≤░πΣ  Learn\n≤▒Υη  Trigger\nΌψΠ  Style\nΌαΧ  Setup\n≤░ΚΚ  Install\n≤░φΝ  Remove\n≤░ΣΡ  Update\nΌσ┤  About\n≤░νΗ  System")"
}

go_to_menu() {
  case "${1,,}" in
  *apps*) omari-apps ;;
  *learn*) show_learn_menu ;;
  *trigger*) show_trigger_menu ;;
  *toggle*) show_toggle_menu ;;
  *style*) show_style_menu ;;
  *background*) show_background_menu ;;
  *theme*) show_theme_menu ;;
  *setup*) show_setup_menu ;;
  *install*) show_install_menu ;;
  *remove*) show_remove_menu ;;
  *update*) show_update_menu ;;
  *about*) show_about ;;
  *system*) show_system_menu ;;
  esac
}

# Allow user extensions and overrides
USER_EXTENSIONS="$HOME/.config/omari/extensions/menu.sh"
[[ -f $USER_EXTENSIONS ]] && source "$USER_EXTENSIONS"

toggle_existing_menu

if [[ -n "$1" ]]; then
  BACK_TO_EXIT=true
  go_to_menu "$1"
else
  show_main_menu
fi