  case $(menu "Install" "ï’‡  1password\nï’‡  Bitwarden\nï‡؟  Discord\nîœ‡  Dropbox\nïچ¶  LibreOffice\nï’‡  LocalSend\nï’‡  ObsStudio\nï’‡  Obsidian\nï’‡  Signal\nï†¼  Spotify\nï’‡  Typora\nï’‡  Tailscale\nï’‡  Zoom") in
