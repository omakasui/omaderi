  case $(menu "Install Databases" "  MySQL\n  PostgreSQL\n  MariaDB\n  Redis\n  MongoDB\n󱘲  MSSQL") in
  *MySQL*) present_terminal "omari-install-docker-dbs mysql" ;;
  *PostgreSQL*) present_terminal "omari-install-docker-dbs postgresql" ;;
  *MariaDB*) present_terminal "omari-install-docker-dbs mariadb" ;;
  *Redis*) present_terminal "omari-install-docker-dbs redis" ;;
  *MongoDB*) present_terminal "omari-install-docker-dbs mongodb" ;;
  *MSSQL*) present_terminal "omari-install-docker-dbs mssql" ;;
  *) show_install_development_menu ;;
  esac
}

