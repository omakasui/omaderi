#!/bin/bash

# Launch the Omari Menu or takes a parameter to jump straight to a submenu.

export PATH="$HOME/.local/share/omari/bin:$PATH"

# Set to true when going directly to a submenu, so we can exit directly
BACK_TO_EXIT=false

back_to() {
  local parent_menu="$1"

  if [[ $BACK_TO_EXIT == "true" ]]; then
    exit 0
  elif [[ -n $parent_menu ]]; then
    "$parent_menu"
  else
    show_main_menu
  fi
}

toggle_existing_menu() {
  if pgrep -f "walker.*--dmenu" >/dev/null; then
    walker --close >/dev/null 2>&1
    exit 0
  fi
}

menu() {
  local prompt="$1"
  local options="$2"
  local extra="$3"
  local preselect="$4"

  read -r -a args <<<"$extra"

  if [[ -n $preselect ]]; then
    local index
    index=$(echo -e "$options" | grep -nxF "$preselect" | cut -d: -f1)
    if [[ -n $index ]]; then
      args+=("-c" "$index")
    fi
  fi

  echo -e "$options" | omari-launch-walker --dmenu --width 295 --minheight 1 --maxheight 630 -p "$prompt…" "${args[@]}" 2>/dev/null
}

terminal() {
  xdg-terminal-exec "$@"
}

present_terminal() {
  omari-launch-floating-terminal-with-presentation "$@"
}

open_in_editor() {
  notify-send -u low "Editing config file" "$1"
  omari-launch-editor "$1"
}

install() {
  present_terminal "echo 'Installing $1...'; omari-pkg-add $2"
}

install_app() {
  present_terminal "echo 'Installing $1...'; omari-app-install $2"
}

install_font() {
  present_terminal "echo 'Installing $1...'; omari-install-font $2 && sleep 2 && omari-font-set '$3'"
}

install_terminal() {
  present_terminal "omari-install-terminal $1"
}

remove() {
  present_terminal "echo 'Removing $1...'; omari-pkg-drop $2"
}

remove_app() {
  present_terminal "echo 'Removing $1...'; omari-app-remove $2"
}

remove_font() {
  present_terminal "echo 'Removing $1...'; omari-remove-font $2"
}

show_learn_menu() {
  case $(menu "Learn" "  Keybindings\n  Omari\n  Debian\n  Niri\n  Neovim\n󱆃  Bash") in
  *Keybindings*) omari-launch-webapp "https://omari.omakasui.org/manual/essentials/hotkeys" "Omari Keybindings" ;;
  *Omari*) omari-launch-webapp "https://omari.omakasui.org/manual" "Omari" ;;
  *Debian*) omari-launch-webapp "https://www.debian.org/doc/" "Debian" ;;
  *Niri*) omari-launch-webapp "https://niri-wm.github.io/niri/" "Niri" ;;
  *Bash*) omari-launch-webapp "https://devhints.io/bash" "Bash" ;;
  *Neovim*) omari-launch-webapp "https://www.lazyvim.org/keymaps" "Neovim" ;;
  *) show_main_menu ;;
  esac
}

show_trigger_menu() {
  case $(menu "Trigger" "  Share\n󰔎  Toggle") in
  *Share*) show_share_menu ;;
  *Toggle*) show_toggle_menu ;;
  *) show_main_menu ;;
  esac
}

show_share_menu() {
  case $(menu "Share" "  Clipboard\n  File \n  Folder") in
  *Clipboard*) omari-cmd-share clipboard ;;
  *File*) terminal bash -c "omari-cmd-share file" ;;
  *Folder*) terminal bash -c "omari-cmd-share folder" ;;
  *) back_to show_trigger_menu ;;
  esac
}

show_toggle_menu() {
  case $(menu "Toggle" "󰔎  Nightlight") in
  *Nightlight*) omari-toggle-nightlight ;;
  *) back_to show_trigger_menu ;;
  esac
}


show_style_menu() {
  case $(menu "Style" "󰸌  Theme\n  Font\n  Background") in
  *Theme*) show_theme_menu ;;
  *Font*) show_font_menu ;;
  *Background*) show_background_menu ;;
  *) show_main_menu ;;
  esac
}

show_theme_menu() {
  omari-launch-walker -m menus:omarithemes --width 800 --minheight 400
}

show_font_menu() {
  theme=$(menu "Font" "$(omari-font-list)" "--width 350" "$(omari-font-current)")
  if [[ $theme == "CNCLD" || -z $theme ]]; then
    back_to show_style_menu
  else
    omari-font-set "$theme"
  fi
}

show_background_menu() {
  omari-launch-walker -m menus:omariBackgroundSelector --width 800 --minheight 400
}

show_setup_menu() {
  case $(menu "Setup" "󰂯  Bluetooth\n󰤆  System Sleep\n  Keybindings") in
  *Bluetooth*) omari-launch-bluetooth ;;
  *System*) show_setup_system_menu ;;
  *Keybindings*) open_in_editor ~/.config/niri/bindings.kdl ;;
  *) show_main_menu ;;
  esac
}

show_setup_system_menu() {
  local options=""

 if [[ -f ~/.local/state/omari/toggles/suspend-off ]]; then
    options="$options󰒲  Enable Suspend"
  else
    options="$options󰒲  Disable Suspend"
  fi

  case $(menu "System" "$options") in
  *Suspend*) omari-toggle-suspend ;;
  *) show_setup_menu ;;
  esac
}

show_install_menu() {
  case $(menu "Install" "  Package\n  Web App\n  TUI\n  Service\n  Browser\n  Utility\n  Style\n󰵮  Development\n  Editor\n  Terminal\n󱚤  AI\n  Gaming") in
  *Package*) terminal omari-pkg-install ;;
  *Web*) present_terminal omari-webapp-install ;;
  *TUI*) present_terminal omari-tui-install ;;
  *Service*) show_install_service_menu ;;
  *Browser*) show_install_browser_menu ;;
  *Utility*) show_install_utility_menu ;;
  *Style*) show_install_style_menu ;;
  *Development*) show_install_development_menu ;;
  *Editor*) show_install_editor_menu ;;
  *Terminal*) show_install_terminal_menu ;;
  *AI*) show_install_ai_menu ;;
  *Gaming*) show_install_gaming_menu ;;
  *) show_main_menu ;;
  esac
}

show_install_service_menu() {
  case $(menu "Install" "  1password\n  Bitwarden\n  Discord\n  Dropbox\n  LibreOffice\n  LocalSend\n  ObsStudio\n  Obsidian\n  Signal\n  Spotify\n  Typora\n  Tailscale\n  Zoom") in
  *1password*) install_app "1password" "1password" ;;
  *Bitwarden*) install_app "Bitwarden" "bitwarden" ;;
  *Discord*) install_app "Discord" "discord" ;;
  *Dropbox*) install_app "Dropbox" "dropbox" ;;
  *LibreOffice*) install "LibreOffice" "libreoffice" ;;
  *LocalSend*) install "LocalSend" "localsend" ;;
  *ObsStudio*) install "ObsStudio" "obs-studio" ;;
  *Obsidian*) install_app "Obsidian" "obsidian" ;;
  *Signal*) install_app "Signal" "signal" ;;
  *Spotify*) install_app "Spotify" "spotify" ;;
  *Typora*) install_app "Typora" "typora" ;;
  *Tailscale*) install_app "Tailscale" "tailscale" ;;
  *Zoom*) install_app "Zoom" "zoom" ;;
  *) show_install_menu ;;
  esac
}

show_install_browser_menu() {
  case $(menu "Install" "  Brave\n  Chromium\n  Firefox\n  Zen") in
  *Brave*) install_app "Brave" "brave" ;;
  *Chromium*) install "Chromium" "chromium" ;;
  *Firefox*) install "Firefox" "firefox-esr" ;;
  *Zen*) install "Zen Browser" "zen-browser" ;;
  *) show_install_menu ;;
  esac
}

show_install_utility_menu() {
  case $(menu "Install" "  Flameshot\n  Pinta\n  Starship\n  Xournalpp") in
  *Flameshot*) install "Flameshot" "flameshot" ;;
  *Pinta*) install "Pinta" "pinta" ;;
  *Starship*) install "Starship" "starship" ;;
  *Xournalpp*) install "Xournalpp" "xournalpp" ;;
  *) show_install_menu ;;
  esac
}

show_install_style_menu() {
  case $(menu "Install" "󰸌  Theme\n  Background\n  Font") in
  *Theme*) present_terminal omari-theme-install ;;
  *Background*) omari-theme-bg-install ;;
  *Font*) show_install_font_menu ;;
  *) show_install_menu ;;
  esac
}

show_install_font_menu() {
  case $(menu "Install" "  Cascadia Mono\n  JetBrains Mono\n  iA Fonts\n  Microsoft Core Fonts" "--width 350") in
  *Cascadia*) install_font "Cascadia Mono" "cascadia-mono" "Cascadia Mono Nerd Font" ;;
  *JetBrains*) install_font "JetBrains Mono" "jetbrains-mono" "JetBrains Mono" ;;
  *iA*) install_font "iA Fonts" "iafonts" "iA Fonts Nerd Font" ;;
  *Microsoft*) install_font "Microsoft Core Fonts" "mscore" "Microsoft Core Fonts" ;;
  *) show_install_menu ;;
  esac
}

show_install_development_menu() {
  case $(menu "Install" "  Docker\n󱘲  Databases\n󰊢  Git\n󰫏  Ruby on Rails\n  JavaScript\n  Go\n  PHP\n  Python\n  Elixir\n  Zig\n  Rust\n  Java\n  .NET\n  OCaml\n  Clojure\n  Scala") in
  *Docker*) install "Docker" "docker" ;;
  *Databases*) show_install_databases_menu ;;
  *Git*) show_install_git_menu ;;
  *Rails*) present_terminal "omari-install-dev-env ruby" ;;
  *JavaScript*) show_install_javascript_menu ;;
  *Go*) present_terminal "omari-install-dev-env go" ;;
  *PHP*) present_terminal "omari-install-dev-env php" ;;
  *Python*) present_terminal "omari-install-dev-env python" ;;
  *Elixir*) show_install_elixir_menu ;;
  *Zig*) present_terminal "omari-install-dev-env zig" ;;
  *Rust*) present_terminal "omari-install-dev-env rust" ;;
  *Java*) present_terminal "omari-install-dev-env java" ;;
  *NET*) present_terminal "omari-install-dev-env dotnet" ;;
  *OCaml*) present_terminal "omari-install-dev-env ocaml" ;;
  *Clojure*) present_terminal "omari-install-dev-env clojure" ;;
  *Scala*) present_terminal "omari-install-dev-env scala" ;;
  *) show_install_menu ;;
  esac
}

