  case $(menu "Remove Development Environment" "َ°«ڈ  Ruby on Rails\nî‍پ  JavaScript\nîک§  Go\nîœ½  PHP\nîœ¼  Python\nîک­  Elixir\nî£¯  Zig\nî‍¨  Rust\nîœ¸  Java\nî‌؟  .NET\nî،ژ  OCaml\nî‌¨  Clojure\nîœ·  Scala") in
