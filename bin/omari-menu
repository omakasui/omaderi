  case $(menu "Install" "ΎΤΘ  Flameshot\nΎΤΘ  Pinta\nΎΕ╡  Starship\nΎΤΘ  Xournalpp") in
  *Flameshot*) install "Flameshot" "flameshot" ;;
  *Pinta*) install "Pinta" "pinta" ;;
  *Starship*) install "Starship" "starship" ;;
