  *Go*) present_terminal "omari-remove-dev-env go" ;;
  *PHP*) present_terminal "omari-remove-dev-env php" ;;
  *Python*) present_terminal "omari-remove-dev-env python" ;;
  *Elixir*) show_remove_elixir_menu ;;
  *Zig*) present_terminal "omari-remove-dev-env zig" ;;
  *Rust*) present_terminal "omari-remove-dev-env rust" ;;
  *Java*) present_terminal "omari-remove-dev-env java" ;;
