  case $(menu "Install" "ïˆں  Docker\nَ±ک²  Databases\nَ°ٹ¢  Git\nَ°«ڈ  Ruby on Rails\nî‍پ  JavaScript\nîک§  Go\nîœ½  PHP\nîœ¼  Python\nîک­  Elixir\nî£¯  Zig\nî‍¨  Rust\nîœ¸  Java\nî‌؟  .NET\nî،ژ  OCaml\nî‌¨  Clojure\nîœ·  Scala") in
