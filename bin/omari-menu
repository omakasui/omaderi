  case $(menu "Install" "Όββ  Cascadia Mono\nΌββ  JetBrains Mono\nΌββ  iA Fonts\nΌββ  Microsoft Core Fonts" "--width 350") in
  *Cascadia*) install_font "Cascadia Mono" "cascadia-mono" "Cascadia Mono Nerd Font" ;;
  *JetBrains*) install_font "JetBrains Mono" "jetbrains-mono" "JetBrains Mono" ;;
  *iA*) install_font "iA Fonts" "iafonts" "iA Fonts Nerd Font" ;;
  *Microsoft*) install_font "Microsoft Core Fonts" "mscore" "Microsoft Core Fonts" ;;
  *) show_install_menu ;;
  esac
}

show_install_development_menu() {
  case $(menu "Install" "ΎΙθ  Docker\n≤▒α▓  Databases\n≤░Λλ  Git\n≤░τΠ  Ruby on Rails\nΌηΒ  JavaScript\nΌαπ  Go\nΌε╜  PHP\nΌε╝  Python\nΌαφ  Elixir\nΌμψ  Zig\nΌηρ  Rust\nΌε╕  Java\nΌζ┐  .NET\nΌκΟ  OCaml\nΌζρ  Clojure\nΌε╖  Scala") in
