#!/bin/bash

# Add the named packages to the system if they're missing. Returns false if it couldn't be done.
# Usage: omari-pkg-add [--no-recommends] package1 package2 ...

APT_EXTRA_OPTS=()
if [[ "$1" == "--no-recommends" ]]; then
  APT_EXTRA_OPTS+=("--no-install-recommends")
  shift
fi

if omari-pkg-missing "$@"; then
  sudo apt-get -y "${APT_EXTRA_OPTS[@]}" install "$@" || exit 1
fi

for pkg in "$@"; do
  # Secondary check to handle states where dpkg doesn't actually register an error
  if ! dpkg-query -W -f='${Status}' "$pkg" 2>/dev/null | grep -q "^install ok installed"; then
    echo -e "\033[31mError: Package '$pkg' did not install\033[0m" >&2
    exit 1
  fi
done

exit 0
