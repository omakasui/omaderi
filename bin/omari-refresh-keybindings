#!/bin/bash

# Refresh the GNOME keybindings to Omari defaults.

# Backup current dconf (with timestamp) to avoid clobbering (Ex: omari.dconf.bak.1753817951)
dconf dump / > "$HOME/keybinding.dconf.bak.$(date +%s)"

# Execute installation GNOME Settings
source ~/.local/share/omari/install/config/gnome/hotkeys.sh
echo -e "\e[31mRefreshed keybindings from Omari defaults. Saved backup as keybinding.dconf.bak.*\e[0m"