#!/bin/bash

# Overwrite the user config for themes with the Omari defaults.

# Add missing theme links
for f in ~/.local/share/omari/themes/*; do
  if [[ ! -e ~/.config/omari/themes/$(basename "$f") ]]; then
    echo -e "\e[32mCreating symlink for $(basename "$f")\e[0m"
    ln -s "$f" ~/.config/omari/themes/
  fi
done


