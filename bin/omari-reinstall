#!/bin/bash
set -e

# Attempt to reinstall all default Omari packages and reset all the default configs.

echo -e "This will reinstall all the default Omari packages and reset all default configs.\nWarning: All user changes to configs will be lost.\n"

if gum confirm "Are you sure you want to reinstall and lose all config changes?"; then
  omari-reinstall-git
  omari-reinstall-pkgs
  omari-reinstall-configs

  gum confirm "System has been reinstalled. Reboot?" && omari-system-reboot
fi
