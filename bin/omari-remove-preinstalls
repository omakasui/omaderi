#!/bin/bash

# Remove preinstalled Omari applications (web apps, TUIs, and selected packages).
# This removes all web apps, TUIs, plus specific desktop applications.

if gum confirm "Are you sure you want to remove all preinstalled web apps, TUI wrappers, and desktop applications?"; then
  echo -e "Removing preinstalled Omari applications...\n"

  omari-webapp-remove-all
  omari-tui-remove-all

  # Remove npx stubs
  rm -f ~/.local/bin/codex ~/.local/bin/gemini ~/.local/bin/copilot ~/.local/bin/claude \
       ~/.local/bin/opencode ~/.local/bin/playwright-cli ~/.local/bin/pi

  omari-pkg-drop \
    spotify \
    libreoffice \
    xournalpp \
    pinta \
    lazydocker
fi