#!/bin/bash

# Set the default terminal emulator for Nautilus to match the one set for Omari.

if [[ -z $1 ]]; then
  echo "Usage: omari-terminal-set-nautilus [terminal-emulator]"
  exit 1
fi

# Check if the specified terminal emulator is installed
if ! command -v "$1" &> /dev/null; then
  echo "Terminal emulator '$1' not found. Please install it first."
  exit 1
fi

gsettings set com.github.stunkymonkey.nautilus-open-any-terminal terminal "$1"
gsettings set com.github.stunkymonkey.nautilus-open-any-terminal keybindings '<Ctrl><Alt>t'
gsettings set com.github.stunkymonkey.nautilus-open-any-terminal new-tab true
gsettings set com.github.stunkymonkey.nautilus-open-any-terminal flatpak system