#!/bin/bash

# Sets the specified image as the current background

if [[ -z $1 ]]; then
  echo "Usage: omari-theme-bg-set <path-to-image>" >&2
  exit 1
fi

BACKGROUND="$1"
CURRENT_BACKGROUND_LINK="$HOME/.config/omari/current/background"

# Create symlink to the new background
ln -nsf "$BACKGROUND" "$CURRENT_BACKGROUND_LINK"

# Create a blurred version of the background
BLURRED_BACKGROUND="$HOME/.config/omari/current/background-blurred.jpg"
convert "$BACKGROUND" -blur 0x15 "$BLURRED_BACKGROUND"

# Kill existing swaybg and start new one
pkill -x swaybg
setsid uwsm-app -- swaybg -i "$CURRENT_BACKGROUND_LINK" -m fill >/dev/null 2>&1 &
setsid uwsm-app -- swaybg -i "$BLURRED_BACKGROUND" -m fill -n backdrop >/dev/null 2>&1 &
