#!/bin/bash

# omari-theme-set: Set a theme, specified by its name.
# Usage: omari-theme-set <theme-name>

if [[ -z $1 ]]; then
  echo "Usage: omari-theme-set <theme-name>" >&2
  exit 1
fi

CURRENT_THEME_PATH="$HOME/.config/omari/current/theme"
NEXT_THEME_PATH="$HOME/.config/omari/current/next-theme"
USER_THEMES_PATH="$HOME/.config/omari/themes"
OMARI_THEMES_PATH="$OMARI_PATH/themes"

THEME_NAME=$(echo "$1" | sed -E 's/<[^>]+>//g' | tr '[:upper:]' '[:lower:]' | tr ' ' '-')
THEME_PATH="$THEMES_DIR/$THEME_NAME"

# Check if the theme entered exists
if [[ ! -d $OMARI_THEMES_PATH/$THEME_NAME ]] && [[ ! -d $USER_THEMES_PATH/$THEME_NAME ]]; then
  echo "Theme '$THEME_NAME' does not exist"
  exit 1
fi

# Setup clean next theme directory (for atomic theme config swapping)
rm -rf "$NEXT_THEME_PATH"
mkdir -p "$NEXT_THEME_PATH"

# Copy official theme first, then overlay user customizations on top
cp -r "$OMARI_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null
cp -r "$USER_THEMES_PATH/$THEME_NAME/"* "$NEXT_THEME_PATH/" 2>/dev/null

# Generate dynamic configs
omari-theme-set-templates

# Swap next theme in as current
rm -rf "$CURRENT_THEME_PATH"
mv "$NEXT_THEME_PATH" "$CURRENT_THEME_PATH"

# Store theme name for reference
echo "$THEME_NAME" > "$HOME/.config/omari/current/theme.name"

# Change background with theme
omari-theme-bg-next

# Restart components to apply new theme
if pgrep -x waybar >/dev/null; then
  omari-restart-waybar
fi
omari-restart-swayosd
omari-restart-terminal
omari-restart-btop
omari-restart-opencode
omari-restart-mako
omari-restart-zellij

# Change app specific themes
omari-theme-set-niri
omari-theme-set-gnome
omari-theme-set-vscode
omari-theme-set-obsidian

# Call hook on theme set
omari-hook theme-set "$THEME_NAME"