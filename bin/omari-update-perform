#!/bin/bash

set -e

# Capture update logs (CLICOLOR_FORCE keeps gum styled when stdout is piped through tee)
export CLICOLOR_FORCE=1
exec > >(tee "/tmp/omari-update.log") 2>&1

omari-update-keyring
omari-update-system-pkgs
omari-migrate
omari-hook post-update
omari-update-restart
omari-update-logout