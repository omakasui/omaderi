# Changes require a restart to take effect.

# Ensure Omari bins are in the path
export OMARI_PATH=$HOME/.local/share/omari
export PATH=$OMARI_PATH/bin:$PATH:$HOME/.local/bin:/usr/sbin:/usr/local/sbin

# Set default terminal and editor
source ~/.config/uwsm/default

# Activate mise if present on the system
omari-cmd-present mise && eval "$(mise activate bash --shims)"
